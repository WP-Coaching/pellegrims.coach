# Database (Recommended: Turso for production, local file for dev)
# Leave empty to use default local file: ./payload-local.db
DATABASE_URI=libsql://your-database-url
DATABASE_AUTH_TOKEN=your-auth-token

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password
CONTACT_EMAIL_DESTINATION=ward@example.com

# Payload CMS
PAYLOAD_SECRET=your-random-secret-string
PAYLOAD_ADMIN_EMAIL=admin@example.com
PAYLOAD_ADMIN_PASSWORD=change-me

# Public URLs
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# S3 Storage (Optional - when unset, uploads use local file storage)
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_ENDPOINT=https://s3.your-provider.com

# Google reCAPTCHA (Optional)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-site-key
RECAPTCHA_SECRET_KEY=your-secret-key
